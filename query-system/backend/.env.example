# ===== 数据源 =====
# auto | api | scraper | mock
DATA_SOURCE_MODE=auto
ALLOW_MOCK_FALLBACK=false
TOP_N=5
CACHE_TTL_HOURS=24
SCRAPER_MIN_DELAY=5
SCRAPER_MAX_DELAY=10
SCRAPER_FETCH_BRAND=false
SCRAPER_FETCH_QA=false

# ----- 第三方 API（推荐，合规）-----
# 供应商示例：rainforest。填入 Key 后 auto 模式将优先走 API。
API_PROVIDER=rainforest
API_KEY=
API_BASE_URL=https://api.rainforestapi.com/request

# ----- 爬虫（回退）-----
SCRAPER_ENABLED=true
# 远程环境预装 Chromium 路径（本地留空用 Playwright 默认）
CHROMIUM_PATH=
SCRAPER_HEADLESS=true
SCRAPER_MIN_DELAY=1.5
SCRAPER_MAX_DELAY=4.0

# ===== 通用 =====
MARKETPLACE=amazon.com
TOP_N=10
REVIEW_SAMPLE_SIZE=40
CACHE_TTL_HOURS=24
CACHE_DB_PATH=cache.db
