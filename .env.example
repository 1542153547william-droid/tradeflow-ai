# Copy to .env and fill in when ready to go live. Until then, provider=mock works.
TRADEFLOW_PROVIDER=mock          # mock | bailian | anthropic
TRADEFLOW_MODEL=claude-opus-4-8  # for bailian use e.g. qwen-plus / qwen-max
TRADEFLOW_MAX_TOKENS=4096

# --- Alibaba Bailian / DashScope (Qwen) — recommended for mainland hosts ---
# Reachable directly from China; no relay needed. Set provider=bailian above,
# TRADEFLOW_MODEL=qwen-plus, and your key here:
DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL defaults to https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Anthropic (Claude) — only if you have an Anthropic key + overseas exit ---
ANTHROPIC_API_KEY=

# --- Mainland-China host only: pick ONE way to reach Anthropic ---
# (api.anthropic.com is blocked from mainland; leave both empty elsewhere.)
#
# Option A (recommended): an overseas relay that forwards to Anthropic.
# ANTHROPIC_BASE_URL=https://your-relay.example.com
#
# Option B: an http/socks proxy the SDK dials through. For socks5 you also
# need `pip install "httpx[socks]"`.
# ANTHROPIC_PROXY=http://user:pass@proxy-host:port
